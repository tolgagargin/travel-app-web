# Copy this file to .env and fill in real keys when you have them.
# Until then, leave USE_MOCK_* as true and the app runs entirely on mock
# data: 50+ sample cities across every continent, templated points of
# interest with synthetic ratings, and a "use current location" that snaps
# to the nearest sample city.
#
# For literally any city/town in the world (not just the built-in list) in
# the city pickers and flight-search fields, set GOOGLE_MAPS_API_KEY and
# USE_MOCK_CITY_SEARCH=false below.

# Set to "false" once flights are configured (Aviasales / Travelpayouts below).
USE_MOCK_FLIGHTS=true

# Set to "false" once hotels are configured (LiteAPI key below). The old
# Hotellook/Travelpayouts cache API is decommissioned, so hotels now use LiteAPI.
USE_MOCK_HOTELS=true

# Hotel provider when USE_MOCK_HOTELS=false:
#   liteapi   — LiteAPI, the live default (free sandbox; LITEAPI_KEY below)
#   amadeus   — legacy; the Amadeus self-service portal is being decommissioned
#               (2026-07-17), so new signups are closed
#   hotellook — dead (endpoints 404), kept only for reference
HOTEL_PROVIDER=liteapi

# Set to "false" once GOOGLE_MAPS_API_KEY is configured, to fetch real
# places sorted by rating from Google Places.
USE_MOCK_PLACES=true

# Set to "false" once GOOGLE_MAPS_API_KEY is configured, to search and
# reverse-geocode any city worldwide via Google Geocoding.
USE_MOCK_CITY_SEARCH=true

# Google Maps Platform — https://console.cloud.google.com/
# Enable the "Places API" and "Geocoding API" on a billing-enabled project
# (Google's $200/month free credit covers normal hobby use), then create an
# API key. Since the key is used client-side from the web app, restrict it
# by HTTP referrer to your app's domain(s).
GOOGLE_MAPS_API_KEY=

# Real flights: which provider when USE_MOCK_FLIGHTS=false — duffel | aviasales
FLIGHT_PROVIDER=duffel

# Duffel — real flights, signup needs only an email (no website).
# https://app.duffel.com/join → Developers → Access tokens → create a sandbox
# token (starts with duffel_test_). Booking is via a Google Flights search link.
DUFFEL_TOKEN=

# Aviasales / Travelpayouts — cheapest-ticket prices + one-click booking links.
# Signup asks for a website (any URL works, e.g. your repo). Token + marker:
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=

# These APIs block browser CORS and the tokens must not ship in any app
# bundle, so requests go through a token-holding proxy. Two options:
#   dev:    dart run tool/flight_proxy.dart  →  FLIGHT_PROXY_URL=http://localhost:8788
#   hosted: the api-proxy Supabase Edge Function (see supabase/README.md)
#           →  FLIGHT_PROXY_URL=https://<ref>.supabase.co/functions/v1/api-proxy
# Use the hosted proxy for web AND mobile builds — then no token is ever
# embedded in the app. Leave blank only for mobile builds that carry their own
# tokens below (not recommended for release).
FLIGHT_PROXY_URL=

# LiteAPI — real hotel search + live prices (the default hotel provider).
# Sign up at https://dashboard.liteapi.travel/register → create a project →
# copy an API key. A free SANDBOX key (starts with "sand_") works against the
# same host; switch to a production key for real inventory.
LITEAPI_KEY=

# Amadeus Self-Service API — LEGACY/optional (HOTEL_PROVIDER=amadeus). The
# self-service portal is being decommissioned on 2026-07-17 so new signups are
# closed; these only work with a pre-existing account. AMADEUS_HOST defaults to
# test.api.amadeus.com (use api.amadeus.com for production).
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_HOST=

# Hotels go through the SAME dev proxy as flights on web (the /amadeus/* route
# of tool/flight_proxy.dart holds the Amadeus secret + does OAuth). Leave this
# blank to reuse FLIGHT_PROXY_URL; set it only to point hotels at a different
# proxy. On mobile, leave blank to call Amadeus directly with the keys above.
HOTEL_PROXY_URL=

# Supabase — accounts (email/password) + cloud sync of saved spots, expenses,
# and preferences. Leave BOTH blank to run fully local (no login, no sync).
# Setup (~2 min): see supabase/README.md. In short:
#   1. Create a free project at https://supabase.com
#   2. Run supabase/migrations/*.sql in the dashboard SQL editor
#   3. Settings → API → copy the Project URL and the "anon"/public key here
# The anon key is safe to ship client-side; row-level security guards the data.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Sentry crash reporting (https://sentry.io — free tier is plenty for a beta).
# Leave blank to disable entirely; the DSN is safe to ship client-side.
SENTRY_DSN=
FLIGHT_PROXY_URL=https://vpfabehhlqekxdqiqaub.supabase.co/functions/v1/api-proxy
USE_MOCK_FLIGHTS=false
FLIGHT_PROVIDER=duffel
USE_MOCK_HOTELS=false
HOTEL_PROVIDER=liteapi
